# ============================================
# Dragon Services Bot - Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# ---- REQUIRED ----

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# PostgreSQL database connection URL
# Format: postgresql://username:password@host:5432/database_name
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/dragon_services

# Secret key for session encryption (generate a random 32+ char string)
SESSION_SECRET=your_random_secret_key_here_make_it_long_and_random

# ---- BOT BEHAVIOUR ----

# Set to "true" to enable the bot (required on VPS)
# On production (NODE_ENV=production) the bot always starts
BOT_ENABLED=true

# ---- OPTIONAL: Override default Discord channel IDs ----

# Channel where customer vouches are posted
VOUCH_CHANNEL_ID=1414374874809368656

# Channel where worker milestone notifications are posted  
WITHDRAWAL_NOTIFICATION_CHANNEL_ID=1449760619292131398

# ---- SERVER ----

# Port the web server listens on (default: 5000)
PORT=5000

# Environment: "production" for VPS, "development" for local testing
NODE_ENV=production
