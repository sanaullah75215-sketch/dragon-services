# ============================================
# Dragon Services Bot - Docker .env file
# Copy this to .env and fill in the 3 values
# ============================================

# Your Discord bot token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Password for the PostgreSQL database (make something up)
DB_PASSWORD=SomeStrongPassword123!

# Random secret for session encryption (make something up)
SESSION_SECRET=someLongRandomStringAtLeast32CharsHere

# Optional: change the port the bot web panel runs on (default 5000)
# PORT=5000
